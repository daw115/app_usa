# ============================================
# DATABASE
# ============================================
# SQLite (default) - local file database
DB_PATH=./app.db

# PostgreSQL (optional) - for production
# DATABASE_URL=postgresql://user:password@localhost/dbname

# ============================================
# ANTHROPIC API (REQUIRED)
# ============================================
# Get your key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Custom API endpoint (optional, for proxy/enterprise)
ANTHROPIC_BASE_URL=

# ============================================
# TELEGRAM BOT (OPTIONAL)
# ============================================
# Create bot: https://t.me/BotFather
# Get chat ID: https://t.me/userinfobot
TELEGRAM_BOT_TOKEN=123456:ABC...
TELEGRAM_CHAT_ID=123456789

# ============================================
# EMAIL CONFIGURATION
# ============================================
# Provider: "gmail" (OAuth, creates drafts) or "smtp" (direct send)
EMAIL_PROVIDER=gmail

# Gmail OAuth (if EMAIL_PROVIDER=gmail)
# Download from: https://console.cloud.google.com/apis/credentials
GMAIL_CLIENT_SECRETS=./gmail_client_secret.json
GMAIL_TOKEN_PATH=./gmail_token.json

# SMTP (if EMAIL_PROVIDER=smtp)
# Example for ATT Mail:
SMTP_HOST=outbound.att.net
SMTP_PORT=465
SMTP_USER=your-email@att.net
SMTP_PASSWORD=your-password
SMTP_FROM=your-email@att.net

# ============================================
# SCRAPERS CREDENTIALS (OPTIONAL)
# ============================================
# Register at: https://copart.com
COPART_USERNAME=
COPART_PASSWORD=

# Register at: https://iaai.com
IAAI_USERNAME=
IAAI_PASSWORD=

# Register at: https://amerpol.com
AMERPOL_USERNAME=
AMERPOL_PASSWORD=

# ScraperAPI (optional, for Copart proxy)
# Get key: https://scraperapi.com
SCRAPERAPI_KEY=

# ============================================
# PUBLIC FORM
# ============================================
# Base URL for client-facing form
# Use cloudflared tunnel URL for production
PUBLIC_FORM_BASE_URL=http://localhost:8000

# ============================================
# OBSERVABILITY (OPTIONAL)
# ============================================
SENTRY_DSN=
ENVIRONMENT=development          # set to "production" on Railway
LOG_FORMAT=text                  # "text" for local, "json" for Railway

# ============================================
# RESOURCE LIMITS
# ============================================
PLAYWRIGHT_TIMEOUT=30000         # ms per page navigation
SCRAPER_PAGE_TIMEOUT=15000       # ms waiting for selectors
AI_TIMEOUT_SECONDS=60            # seconds per AI analysis
AI_MAX_PHOTOS=6                  # max photos per listing
SCRAPER_DAILY_LIMIT=30           # max scrapes/day per source (anti-ban)
